      "files": [
        {
          "path": "set4/1.mp3",
          "durationSec": 2.881,
          "text": "Tal vez haya un poema si nos quedamos"
        },
        {
          "path": "set4/2.mp3",
          "durationSec": 2.307,
          "text": "¿Esto sería un poema?"
        },
        {
          "path": "set4/3.mp3",
          "durationSec": 2.934,
          "text": "Si estás quieta no lo sientes"
        },
        {
          "path": "set4/4.mp3",
          "durationSec": 3.038,
          "text": "No hemos visto pasar casi nada"
        },
        {
          "path": "set4/5.mp3",
          "durationSec": 9.987,
          "text": "El cielo encierra dentro de sí todos los cuerpos, y fuera de él no existe lugar, ni tiempo, ni vacío"
        },
        {
          "path": "set4/6.mp3",
          "durationSec": 4.266,
          "text": "Esto ya es hermoso, yo podría quedarme aquí"
        },
        {
          "path": "set4/7.mp3",
          "durationSec": 2.228,
          "text": "Es hermoso"
        },
        {
          "path": "set4/8.mp3",
          "durationSec": 2.333,
          "text": "Yo temo chocar"
        },
        {
          "path": "set4/9.mp3",
          "durationSec": 2.046,
          "text": "Yo temo caer"
        },
        {
          "path": "set4/11.mp3",
          "durationSec": 1.967,
          "text": "¿Estamos quietos?"
        },
        {
          "path": "set4/11.mp3",
          "durationSec": 1.967,
          "text": "¿Estamos quietos?"
        },
        {
          "path": "set4/12.mp3",
          "durationSec": 2.516,
          "text": "¿Nosotros dónde estamos?"
        },
        {
          "path": "set4/13.mp3",
          "durationSec": 2.751,
          "text": "Es un movimiento circular"
        },
        {
          "path": "set4/14.mp3",
          "durationSec": 2.333,
          "text": "Ha sido muy bonito"
        },
        {
          "path": "set4/15.mp3",
          "durationSec": 2.777,
          "text": "Es que a veces el ruido es mucho"
        },
        {
          "path": "set4/16.mp3",
          "durationSec": 2.411,
          "text": "¿Eso ha sido un poema?"
        },
        {
          "path": "set4/17.mp3",
          "durationSec": 4.893,
          "text": "La música dice, no hemos muerto aún"
        },
        {
          "path": "set4/18.mp3",
          "durationSec": 4.188,
          "text": "El ritmo dice, no hemos muerto aún"
        },
        {
          "path": "set4/19.mp3",
          "durationSec": 2.829,
          "text": "¿Está anocheciendo?"
        },
        {
          "path": "set4/20.mp3",
          "durationSec": 2.176,
          "text": "Esto es muy hermoso"
        },
        {
          "path": "set4/21.mp3",
          "durationSec": 2.672,
          "text": "¿Estamos perdiendo el tiempo?"
        },
        {
          "path": "set4/22.mp3",
          "durationSec": 2.255,
          "text": "¿Puedo ponerme a tu lado?"
        },
        {
          "path": "set4/24.mp3",
          "durationSec": 5.363,
          "text": "¿Por qué habría que moverse tanto si ya tantas cosas se mueven?"
        },
        {
          "path": "set4/25.mp3",
          "durationSec": 2.881,
          "text": "No dejamos pasar nada"
        },
        {
          "path": "set4/26.mp3",
          "durationSec": 2.098,
          "text": "Eso es muy hermoso"
        },
        {
          "path": "set4/27.mp3",
          "durationSec": 5.494,
          "text": "Me gusta escucharte sin ir hacia ti, sin superar la distancia"
        },
        {
          "path": "set4/28.mp3",
          "durationSec": 2.15,
          "text": "No voy a ir hacia ti"
        },
        {
          "path": "set4/29.mp3",
          "durationSec": 3.247,
          "text": "Podría estallar, pero no estalla"
        },
        {
          "path": "set4/30.mp3",
          "durationSec": 3.012,
          "text": "Hay que irse, pero no muy lejos"
        },
        {
          "path": "set4/31.mp3",
          "durationSec": 3.952,
          "text": "El ritmo de las presencias y las ausencias"
        },
        {
          "path": "set4/32.mp3",
          "durationSec": 2.046,
          "text": "La música"
        },
        {
          "path": "set4/33.mp3",
          "durationSec": 1.68,
          "text": "El movimiento"
        },
        {
          "path": "set4/34.mp3",
          "durationSec": 2.542,
          "text": "¿Cuánto tiempo se puede estar así?"
        },
        {
          "path": "set4/35.mp3",
          "durationSec": 2.62,
          "text": "Estamos yendo, algo nos llama"
        },
        {
          "path": "set4/36.mp3",
          "durationSec": 2.542,
          "text": "Ha sido muy bonito"
        },
        {
          "path": "set4/37.mp3",
          "durationSec": 1.471,
          "text": "Tenemos que hablar"
        },
        {
          "path": "set4/38.mp3",
          "durationSec": 1.758,
          "text": "Todavía no"
        },
        {
          "path": "set4/39.mp3",
          "durationSec": 2.594,
          "text": "¿Eso ha sido un poema?"
        },
        {
          "path": "set4/40.mp3",
          "durationSec": 2.934,
          "text": "Algo tiene que haber que llame"
        },
        {
          "path": "set4/41.mp3",
          "durationSec": 2.516,
          "text": "¿Te sientes llamado por mí?"
        },
        {
          "path": "set4/42.mp3",
          "durationSec": 5.494,
          "text": "Yo podría ir ahora de aquí hasta allí, hasta donde estás tú"
        },
        {
          "path": "set4/43.mp3",
          "durationSec": 1.758,
          "text": "Es hermoso"
        },
        {
          "path": "set4/44.mp3",
          "durationSec": 2.542,
          "text": "Pensar en algo es como llamarlo"
        },
        {
          "path": "set4/45.mp3",
          "durationSec": 1.837,
          "text": "Lo hemos pensado"
        },
        {
          "path": "set4/46.mp3",
          "durationSec": 4.318,
          "text": "Algo que está allí o más allá llama"
        },
        {
          "path": "set4/47.mp3",
          "durationSec": 3.325,
          "text": "Es la cosa que lo llama, no es que quiera"
        },
        {
          "path": "set4/48.mp3",
          "durationSec": 2.855,
          "text": "Está bien que hablemos"
        },
        {
          "path": "set4/49.mp3",
          "durationSec": 4.397,
          "text": "Se mueve hacia algo, algo que necesita"
        },
        {
          "path": "set4/50.mp3",
          "durationSec": 1.549,
          "text": "Se mueve"
        },
        {
          "path": "set4/51.mp3",
          "durationSec": 1.628,
          "text": "¿Qué ves en mí?"
        },
        {
          "path": "set4/52.mp3",
          "durationSec": 2.098,
          "text": "¿Crees que hemos cambiado?"
        },
        {
          "path": "set4/53.mp3",
          "durationSec": 2.908,
          "text": "Estábamos pensando en otras cosas"
        },
        {
          "path": "set4/54.mp3",
          "durationSec": 1.837,
          "text": "¿Lo has sentido?"
        },
        {
          "path": "set4/55.mp3",
          "durationSec": 2.046,
          "text": "¿Cuánto tiempo ha pasado?"
        },
        {
          "path": "set4/56.mp3",
          "durationSec": 4.945,
          "text": "Hay cosas demasiado pesadas que no las puede desplazar el viento"
        },
        {
          "path": "set4/57.mp3",
          "durationSec": 2.803,
          "text": "¿ Es el viento el que mueve las cosas ?"
        },
        {
          "path": "set4/58.mp3",
          "durationSec": 2.046,
          "text": "¿Es el viento?"
        },
        {
          "path": "set4/59.mp3",
          "durationSec": 4.606,
          "text": "Se ha movido algo que nos ha puesto muy cerca"
        }
      ]
